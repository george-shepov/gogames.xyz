# GoGames.XYZ Server Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file — it is in .gitignore.

# ── Server ──────────────────────────────────────────────────
PORT=3000

# The origin(s) allowed for CORS — comma-separated list of exact origins.
# In production, set this to your domain(s). Defaults to localhost in development.
# Example: ALLOWED_ORIGIN=https://www.gogames.xyz,https://gogames.xyz
ALLOWED_ORIGIN=https://www.gogames.xyz

# ── Stripe ──────────────────────────────────────────────────
# Your Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Your Stripe webhook secret (from Stripe Dashboard → Webhooks)
# Required only if you use the /api/stripe-webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── Frontend Stripe public key ───────────────────────────────
# Injected into pay.html via __STRIPE_PK__ window variable
# (set this via your deployment config or a template engine)
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
